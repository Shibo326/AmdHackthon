# ============================================
# Clausify AI — .gitignore
# ============================================

# --- Dependencies ---
node_modules/
frontend/node_modules/
/.pnp
.pnp.js
.yarn/install-state.gz

# --- Python ---
venv/
.venv/
backend/venv*/
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.hypothesis/

# --- Build outputs ---
frontend/dist/
/build

# --- Environment files (SECRETS — NEVER COMMIT) ---
.env
.env.local
.env*.local
backend/.env
backend/.env.local
frontend/.env

# --- Persistent data (sessions + ChromaDB) ---
backend/data/sessions/*.json
backend/data/chroma/

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- OS ---
.DS_Store
Thumbs.db

# --- Testing / Coverage ---
/coverage
*.tsbuildinfo

# --- Misc ---
*.pem
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Vercel ---
.vercel

# --- Nested duplicate folders (accidentally copied) ---
AmdHackthon/

# --- Old artifacts (not part of the project) ---
DEALFLOW_AI_KIRO_STEERING.md
DEALFLOW_AI_MASTER_PLAN.md
convert_to_pdf.py
Investment Proposal.docx
postcss.config.js
tailwind.config.js
/package-lock.json
/tsconfig.json
