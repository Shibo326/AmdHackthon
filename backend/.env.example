# Fireworks AI (AMD MI300X) — required
FIREWORKS_API_KEY=fw_your_fireworks_api_key_here
FIREWORKS_ENDPOINT=https://api.fireworks.ai/inference/v1

# Tiered model config (PERF OPTIMIZATION)
# FIREWORKS_MODEL_QUALITY — deep reasoning model for summaries, risks, recommendations
FIREWORKS_MODEL_QUALITY=accounts/fireworks/models/deepseek-v4-0324
# FIREWORKS_MODEL_FAST — AMD MI300X optimised fast model for matrix, questions, conflict detection
FIREWORKS_MODEL_FAST=accounts/fireworks/models/gpt-oss-120b

# Legacy single-model config (used as fallback if QUALITY/FAST not set)
# FIREWORKS_MODEL=accounts/fireworks/models/gpt-oss-120b

# Single-call mode: combine ALL analysis into ONE LLM call (extreme speed, lower quality)
# Set to true only as emergency fallback if tiered calls are still too slow
SINGLE_CALL_MODE=false

# CORS — comma-separated origins (default: all)
ALLOWED_ORIGINS=http://localhost:3000

# Server port
PORT=8000

# Persistence directories (optional — defaults to backend/data/)
# SESSION_PERSIST_DIR=/path/to/sessions
# CHROMA_PERSIST_DIR=/path/to/chroma
