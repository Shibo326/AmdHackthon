# Fireworks AI (AMD MI300X) — required
FIREWORKS_API_KEY=fw_your_fireworks_api_key_here
# llama-4-maverick: 200-300 tok/s, MoE 400B (17B active), beats GPT-4o on doc analysis
FIREWORKS_MODEL=accounts/fireworks/models/llama-4-maverick-instruct
FIREWORKS_ENDPOINT=https://api.fireworks.ai/inference/v1

# CORS — comma-separated origins (default: all)
ALLOWED_ORIGINS=http://localhost:3000

# Server port
PORT=8000

# Persistence directories (optional — defaults to backend/data/)
# SESSION_PERSIST_DIR=/path/to/sessions
# CHROMA_PERSIST_DIR=/path/to/chroma
